{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://more-phi.local/schemas/dataset-candidate.schema.json",
  "title": "Neural Mastering Dataset Candidate",
  "type": "object",
  "examples": [
    {
      "id": "sonicmaster-dataset",
      "name": "SonicMasterDataset",
      "sourceUrl": "https://huggingface.co/datasets/amaai-lab/SonicMasterDataset",
      "sourceCategory": "open-source",
      "datasetType": "paired",
      "scaleSummary": "Approximately 166k paired degraded/high-quality music rows",
      "audioFormat": {
        "sampleRate": 44100,
        "channels": "stereo",
        "encoding": "FLAC",
        "alignmentNotes": "Paired input and target files"
      },
      "labelingType": "paired degraded/high-quality audio with degradation metadata",
      "recommendedRole": [
        "primary-paired-training"
      ],
      "recommendationStatus": "research-only",
      "compatibilityScore": 5,
      "licensePostureId": "license-sonicmaster-dataset",
      "overfittingRiskId": "risk-sonicmaster-dataset",
      "requiredFollowUps": [
        "Audit source IDs and item-level attribution before ingestion"
      ],
      "evidenceLinks": [
        "https://huggingface.co/datasets/amaai-lab/SonicMasterDataset"
      ]
    }
  ],
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "sourceUrl",
    "sourceCategory",
    "datasetType",
    "scaleSummary",
    "audioFormat",
    "labelingType",
    "recommendedRole",
    "recommendationStatus",
    "compatibilityScore",
    "licensePostureId",
    "overfittingRiskId",
    "requiredFollowUps",
    "evidenceLinks"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "sourceUrl": {
      "type": "string",
      "format": "uri"
    },
    "sourceCategory": {
      "enum": [
        "academic",
        "open-source",
        "industry-standard",
        "commercial",
        "rejected-source"
      ]
    },
    "datasetType": {
      "enum": [
        "paired",
        "multitrack",
        "reference-only",
        "quality-benchmark",
        "effect-specific",
        "synthetic",
        "commercial-source"
      ]
    },
    "scaleSummary": {
      "type": "string",
      "minLength": 1
    },
    "audioFormat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sampleRate",
        "channels",
        "encoding",
        "alignmentNotes"
      ],
      "properties": {
        "sampleRate": {
          "type": [
            "integer",
            "string"
          ]
        },
        "channels": {
          "type": "string",
          "minLength": 1
        },
        "encoding": {
          "type": "string",
          "minLength": 1
        },
        "alignmentNotes": {
          "type": "string"
        }
      }
    },
    "labelingType": {
      "type": "string",
      "minLength": 1
    },
    "recommendedRole": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "primary-paired-training",
          "synthetic-pair-generation",
          "auxiliary-pretraining",
          "reference-distribution",
          "perceptual-validation",
          "pipeline-debugging",
          "hold",
          "reject"
        ]
      }
    },
    "recommendationStatus": {
      "enum": [
        "recommended",
        "conditional",
        "research-only",
        "validation-only",
        "hold",
        "rejected"
      ]
    },
    "compatibilityScore": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "licensePostureId": {
      "type": "string",
      "minLength": 1
    },
    "overfittingRiskId": {
      "type": "string",
      "minLength": 1
    },
    "requiredFollowUps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidenceLinks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
