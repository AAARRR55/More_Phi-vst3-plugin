 def now_iso() -> str:
     return datetime.now(timezone.utc).isoformat()
 
 
+def unix_seconds(dt: datetime) -> int:
+    return int(dt.timestamp())
+
+
+def b64url(data: bytes) -> str:
+    return base64.urlsafe_b64encode(data).decode().rstrip("=")
+
+
+def canonical_json(payload: Dict[str, Any]) -> bytes:
+    import json
+    return json.dumps(payload, separators=(",", ":"), sort_keys=True).encode("utf-8")
+
+
+def signing_key() -> Ed25519PrivateKey:
+    if not LICENSE_SIGNING_PRIVATE_KEY_PEM:
+        raise HTTPException(status_code=503, detail="License signing key is not configured")
+    key = load_pem_private_key(LICENSE_SIGNING_PRIVATE_KEY_PEM.encode(), password=None)
+    if not isinstance(key, Ed25519PrivateKey):
+        raise HTTPException(status_code=500, detail="LICENSE_SIGNING_PRIVATE_KEY_PEM must be an Ed25519 private key")
+    return key
+
+
+def sign_activation_certificate(license_doc: Dict[str, Any], activation: Dict[str, Any]) -> Dict[str, str]:
+    now = datetime.now(timezone.utc)
+    next_check = now + timedelta(days=30)
+    grace_until = next_check + timedelta(days=14)
+    payload = {
+        "schema": "morephi-license-cert-v1",
+        "licenseId": license_doc["id"],
+        "activationId": activation["id"],
+        "productId": PRODUCT["id"],
+        "licenseType": "perpetual",
+        "features": ["morph_pad", "plugin_hosting", "mcp", "premium_presets", "audio_domain_morphing"],
+        "issuedAtUnix": unix_seconds(now),
+        "validFromUnix": unix_seconds(now),
+        "validUntilUnix": None,
+        "trialEndsAtUnix": None,
+        "subscriptionEndsAtUnix": None,
+        "leaseEndsAtUnix": None,
+        "nextOnlineCheckAtUnix": unix_seconds(next_check),
+        "offlineGraceEndsAtUnix": unix_seconds(grace_until),
+        "machineHash": activation["machine_id"],
+        "nonce": secrets.token_urlsafe(16),
+    }
+    payload_bytes = canonical_json(payload)
+    signature = signing_key().sign(payload_bytes)
+    return {
+        "certificate_payload": b64url(payload_bytes),
+        "signature": b64url(signature),
+        "public_key_id": LICENSE_SIGNING_KEY_ID,
+    }
+
