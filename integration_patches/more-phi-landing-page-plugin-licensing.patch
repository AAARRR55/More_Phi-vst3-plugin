+async def verify_plugin_client(request: Request) -> None:
+    if not MOREPHI_PUBLIC_CLIENT_TOKEN:
+        raise HTTPException(status_code=503, detail="Plugin activation token is not configured")
+    provided = request.headers.get("X-MorePhi-Client")
+    if not provided or not hmac.compare_digest(provided, MOREPHI_PUBLIC_CLIENT_TOKEN):
+        raise HTTPException(status_code=401, detail="Invalid plugin client token")
+
