+async def find_plugin_license(license_key: str, product_id: str) -> Dict[str, Any]:
+    license_doc = await db.licenses.find_one({"license_key": license_key, "product_id": product_id}, {"_id": 0})
+    if not license_doc or license_doc.get("status") != "active":
+        raise HTTPException(status_code=404, detail="Active license not found")
+    return license_doc
+
+
+@app.post("/api/plugin/licenses/activate", response_model=PluginLicenseResponse)
+async def plugin_activate_license(payload: PluginActivationCreate, request: Request) -> PluginLicenseResponse:
+    await verify_plugin_client(request)
+    await rate_limit(request, "plugin_activate", 30, 900)
+    license_doc = await find_plugin_license(payload.license_key, payload.product_id)
+    existing = await db.license_activations.find_one({"license_key": payload.license_key, "machine_id": payload.machine_id}, {"_id": 0})
+    if existing and existing.get("status") == "active":
+        certificate = sign_activation_certificate(license_doc, existing)
+        return PluginLicenseResponse(status="active", activation_id=existing["id"], license_key=payload.license_key, machine_id=payload.machine_id, **certificate)
+
+    count = await db.license_activations.count_documents({"license_key": payload.license_key, "status": "active"})
+    if count >= license_doc["activation_limit"]:
+        raise HTTPException(status_code=403, detail="Activation limit reached")
+
+    activation = {
+        "id": str(uuid4()),
+        "license_key": payload.license_key,
+        "customer_id": license_doc["customer_id"],
+        "machine_id": payload.machine_id,
+        "host_name": payload.platform,
+        "daw": payload.daw,
+        "plugin_version": payload.plugin_version,
+        "status": "active",
+        "activated_at": now_iso(),
+        "last_seen_at": now_iso(),
+    }
+    await db.license_activations.insert_one(activation)
+    certificate = sign_activation_certificate(license_doc, activation)
+    return PluginLicenseResponse(status="active", activation_id=activation["id"], license_key=payload.license_key, machine_id=payload.machine_id, **certificate)
+
+
+@app.post("/api/plugin/licenses/refresh", response_model=PluginLicenseResponse)
+async def plugin_refresh_license(payload: PluginRefreshCreate, request: Request) -> PluginLicenseResponse:
+    await verify_plugin_client(request)
+    await rate_limit(request, "plugin_refresh", 120, 900)
+    activation = await db.license_activations.find_one({"id": payload.activation_id, "machine_id": payload.machine_id}, {"_id": 0})
+    if not activation or activation.get("status") != "active":
+        raise HTTPException(status_code=404, detail="Active activation not found")
+    license_doc = await find_plugin_license(activation["license_key"], payload.product_id)
+    await db.license_activations.update_one({"id": activation["id"]}, {"$set": {"last_seen_at": now_iso()}})
+    activation["last_seen_at"] = now_iso()
+    certificate = sign_activation_certificate(license_doc, activation)
+    return PluginLicenseResponse(status="active", activation_id=activation["id"], license_key=activation["license_key"], machine_id=payload.machine_id, **certificate)
+
+
+@app.post("/api/plugin/licenses/deactivate")
+async def plugin_deactivate_license(payload: PluginDeactivateCreate, request: Request) -> Dict[str, str]:
+    await verify_plugin_client(request)
+    await rate_limit(request, "plugin_deactivate", 30, 900)
+    activation = await db.license_activations.find_one({"id": payload.activation_id, "machine_id": payload.machine_id}, {"_id": 0})
+    if not activation or activation.get("status") != "active":
+        raise HTTPException(status_code=404, detail="Active activation not found")
+    await find_plugin_license(activation["license_key"], payload.product_id)
+    await db.license_activations.update_one({"id": activation["id"]}, {"$set": {"status": "deactivated", "deactivated_at": now_iso()}})
+    return {"status": "deactivated", "activation_id": activation["id"]}
