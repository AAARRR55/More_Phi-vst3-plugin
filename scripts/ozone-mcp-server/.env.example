# Copy this file to .env and populate with real values.
# NEVER commit .env to source control.

# Ozone Track Assistant API credentials
OZONE_API_KEY=ozk_prod_xxxxxxxxxxxxxxxxxxxx
OZONE_BASE_URL=https://internal.ozone.yourdomain.com/api/v1

# Optional: cookie-based auth alternative to API key
# OZONE_SESSION_COOKIE=sess_token_if_cookie_auth

# Optional: shared secret used to authenticate the AI agent calling this MCP server
# MCP_AUTH_SECRET=mcp_secret_for_client_validation
