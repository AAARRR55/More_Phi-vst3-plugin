# .clang-tidy
# MorphSnap v2 — clang-tidy configuration
#
# Design philosophy:
#   - Audio-thread safety is the top priority: no heap allocation,
#     no throwing, no locks on the processBlock() path.
#   - All warnings that can indicate RT unsafety are set to error.
#   - JUCE generates code that triggers some checks; suppress those
#     specifically rather than disabling whole check families.
#
# Usage:
#   clang-tidy src/Core/MorphProcessor.cpp -- -std=c++20 -I src
#
# CMake integration (cmake/CompilerFlags.cmake already sets):
#   set(CMAKE_CXX_CLANG_TIDY "clang-tidy;--config-file=${CMAKE_SOURCE_DIR}/.clang-tidy")

---
Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  cert-*,
  -cert-err58-cpp,
  clang-analyzer-*,
  clang-analyzer-cplusplus.*,
  concurrency-*,
  cppcoreguidelines-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  hicpp-*,
  -hicpp-avoid-c-arrays,
  -hicpp-no-array-decay,
  misc-*,
  -misc-non-private-member-variables-in-classes,
  modernize-*,
  -modernize-use-trailing-return-type,
  performance-*,
  portability-*,
  readability-*,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity,
  -readability-identifier-length

# Promote critical checks to errors.
# These are the checks most likely to indicate RT-unsafe or data-race-prone code.
WarningsAsErrors: >
  bugprone-use-after-move,
  bugprone-undefined-memory-manipulation,
  bugprone-infinite-loop,
  cert-err33-c,
  clang-analyzer-cplusplus.NewDelete,
  clang-analyzer-cplusplus.NewDeleteLeaks,
  clang-analyzer-core.NullDereference,
  clang-analyzer-core.uninitialized.Assign,
  concurrency-mt-unsafe,
  cppcoreguidelines-pro-type-reinterpret-cast,
  misc-throw-by-value-catch-by-reference,
  performance-unnecessary-copy-initialization,
  performance-move-const-arg

HeaderFilterRegex: "^.*/src/.*\\.h$"

CheckOptions:
  # ─── Naming conventions ────────────────────────────────────────────────────
  - key:   readability-identifier-naming.ClassCase
    value: CamelCase
  - key:   readability-identifier-naming.StructCase
    value: CamelCase
  - key:   readability-identifier-naming.FunctionCase
    value: camelCase
  - key:   readability-identifier-naming.MethodCase
    value: camelCase
  - key:   readability-identifier-naming.VariableCase
    value: camelCase
  - key:   readability-identifier-naming.ParameterCase
    value: camelCase
  - key:   readability-identifier-naming.MemberCase
    value: camelCase
  - key:   readability-identifier-naming.MemberSuffix
    value: "_"
  - key:   readability-identifier-naming.PrivateMemberCase
    value: camelCase
  - key:   readability-identifier-naming.PrivateMemberSuffix
    value: "_"
  - key:   readability-identifier-naming.EnumCase
    value: CamelCase
  - key:   readability-identifier-naming.EnumConstantCase
    value: CamelCase
  - key:   readability-identifier-naming.ConstantCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.NamespaceCase
    value: lower_case

  # ─── Function size ─────────────────────────────────────────────────────────
  - key:   readability-function-size.LineThreshold
    value: "60"
  - key:   readability-function-size.StatementThreshold
    value: "40"
  - key:   readability-function-size.BranchThreshold
    value: "10"
  - key:   readability-function-size.ParameterThreshold
    value: "8"

  # ─── modernize ─────────────────────────────────────────────────────────────
  - key:   modernize-use-default-member-init.UseAssignment
    value: "true"
  - key:   modernize-loop-convert.MinConfidence
    value: reasonable

  # ─── cppcoreguidelines ─────────────────────────────────────────────────────
  # Allow raw pointer params (JUCE APIs use them extensively)
  - key:   cppcoreguidelines-pro-type-vararg.WarnOnCStyleCast
    value: "false"
  # Owning raw pointers through JUCE RAII are acceptable
  - key:   cppcoreguidelines-owning-memory.LegacyResourceProducers
    value: "::malloc;::calloc;::realloc"

  # ─── performance ───────────────────────────────────────────────────────────
  - key:   performance-for-range-copy.WarnOnAllAutoCopies
    value: "true"
  - key:   performance-inefficient-string-concatenation.StrictMode
    value: "true"

  # ─── bugprone ──────────────────────────────────────────────────────────────
  - key:   bugprone-argument-comment.StrictMode
    value: "true"
  - key:   bugprone-assert-side-effect.AssertMacros
    value: "jassert,DBG_ASSERT"
  - key:   bugprone-suspicious-string-compare.WarnOnImplicitComparison
    value: "true"

  # ─── misc ──────────────────────────────────────────────────────────────────
  - key:   misc-const-correctness.WarnPointersAsValues
    value: "false"
